---
# Sample only. Provider-specific overrides for OCI targets.

oci_cluster:
  region: ap-seoul-1
  tenancy_ocid: ocid1.tenancy.oc1..exampleuniqueid
  compartment_ocid: ocid1.compartment.oc1..exampleuniqueid
  vcn_ocid: ocid1.vcn.oc1.ap-seoul-1.exampleuniqueid
  worker_subnet_ocids:
    - ocid1.subnet.oc1.ap-seoul-1.exampleworker1
    - ocid1.subnet.oc1.ap-seoul-1.exampleworker2
  ingress_subnet_ocids:
    - ocid1.subnet.oc1.ap-seoul-1.examplelb1
    - ocid1.subnet.oc1.ap-seoul-1.examplelb2
  cluster_name: moadev-oke
  kubernetes_version: v1.30.1
  node_pool_name: moadev-general
  node_pool_shape: VM.Standard.E4.Flex
  node_pool_size: 3
  workload_placement: availability-domain-spread

ingress:
  load_balancer_shape: flexible
  load_balancer_min_mbps: 10
  load_balancer_max_mbps: 100

storage:
  storage_class: oci-bv
