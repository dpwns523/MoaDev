# Shared article persistence baseline for services/api and services/agents-runtime.
DATABASE_URL=postgresql+psycopg://moadev:change-me@localhost:5432/moadev

# Shared with apps/web so the API can verify the signed internal bearer token.
MOADEV_INTERNAL_AUTH_SECRET=

# Optional maximum age, in seconds, for the forwarded authenticated token.
MOADEV_INTERNAL_AUTH_MAX_AGE_SECONDS=300
