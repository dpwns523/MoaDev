# Sample only. Layer these AWS-specific values on top of global.env.example outside version control.

# AWS cluster
MOADEV_AWS_REGION=us-west-2
MOADEV_AWS_ACCOUNT_ID=123456789012
MOADEV_AWS_VPC_ID=vpc-0123456789example
MOADEV_AWS_PRIVATE_SUBNET_IDS=subnet-aaaexample,subnet-bbbexample
MOADEV_AWS_PUBLIC_SUBNET_IDS=subnet-cccexample,subnet-dddexample
MOADEV_AWS_CLUSTER_NAME=moadev-eks
MOADEV_AWS_KUBERNETES_VERSION=1.30
MOADEV_AWS_NODE_GROUP_NAME=moadev-general
MOADEV_AWS_NODE_GROUP_INSTANCE_TYPE=m6i.large
MOADEV_AWS_NODE_GROUP_DESIRED_SIZE=3

# AWS ingress and storage overrides
MOADEV_AWS_STORAGE_CLASS=gp3
MOADEV_AWS_INGRESS_CLASS=alb
MOADEV_AWS_LOAD_BALANCER_SCHEME=internet-facing
MOADEV_AWS_CLUSTER_AUTOSCALER_EXPANDER=least-waste
MOADEV_AWS_SPOT_ENABLED=false
