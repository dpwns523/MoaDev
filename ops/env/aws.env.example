# Sample only. Layer these AWS-specific values on top of global.env.example outside version control.

# AWS control plane and worker nodes
MOADEV_AWS_REGION=us-west-2
MOADEV_AWS_ACCOUNT_ID=123456789012
MOADEV_AWS_VPC_ID=vpc-0123456789example
MOADEV_AWS_CONTROL_PLANE_SUBNET_IDS=subnet-aaaexample,subnet-bbbexample
MOADEV_AWS_WORKER_SUBNET_IDS=subnet-eeeexample,subnet-fffexample
MOADEV_AWS_PUBLIC_LOAD_BALANCER_SUBNET_IDS=subnet-cccexample,subnet-dddexample
MOADEV_AWS_CONTROL_PLANE_INSTANCE_TYPE=m6i.large
MOADEV_AWS_CONTROL_PLANE_DESIRED_COUNT=1
MOADEV_AWS_CONTROL_PLANE_MIN_COUNT=1
MOADEV_AWS_CONTROL_PLANE_MAX_COUNT=3
MOADEV_AWS_WORKER_INSTANCE_TYPE=m6i.large
MOADEV_AWS_WORKER_DESIRED_COUNT=3
MOADEV_AWS_WORKER_MIN_COUNT=3
MOADEV_AWS_WORKER_MAX_COUNT=6
MOADEV_AWS_WORKER_SPOT_ENABLED=false

# AWS ingress and storage overrides
MOADEV_AWS_STORAGE_CLASS=gp3
MOADEV_AWS_LOAD_BALANCER_SCHEME=internet-facing
