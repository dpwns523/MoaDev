# Sample only. Copy to a local env file and replace with deployment-specific values outside version control.

# Cluster topology
MOADEV_PLATFORM_TOPOLOGY=multicloud
MOADEV_CLUSTER_NAME=moadev-multicloud
MOADEV_CONTROL_PLANE_PROVIDER=aws
MOADEV_KUBERNETES_VERSION=1.34.2
MOADEV_CNI_PLUGIN=calico
MOADEV_POD_CIDR=10.0.0.0/16
MOADEV_SERVICE_CIDR=10.96.0.0/12

# Domains
MOADEV_BASE_DOMAIN=moadev.example.invalid
MOADEV_WEB_DOMAIN=app.moadev.example.invalid
MOADEV_API_DOMAIN=api.moadev.example.invalid
MOADEV_ARGOCD_DOMAIN=argocd.moadev.example.invalid
MOADEV_GRAFANA_DOMAIN=grafana.moadev.example.invalid

# Images and registry
MOADEV_CONTAINER_REGISTRY=registry.example.invalid/moadev
MOADEV_WEB_IMAGE_REPOSITORY=web
MOADEV_API_IMAGE_REPOSITORY=api
MOADEV_AGENTS_RUNTIME_IMAGE_REPOSITORY=agents-runtime
MOADEV_IMAGE_TAG=stable

# Namespaces
MOADEV_APP_NAMESPACE=moadev
MOADEV_PLATFORM_NAMESPACE=moadev-platform
MOADEV_MONITORING_NAMESPACE=moadev-monitoring
MOADEV_CICD_NAMESPACE=moadev-cicd

# Ingress and scheduling
MOADEV_INGRESS_CLASS=nginx
MOADEV_INGRESS_REPLICA_COUNT=2
MOADEV_INGRESS_LOAD_BALANCER_PROVIDER=aws
MOADEV_DEFAULT_NODE_GROUP=aws_workers
MOADEV_SCHEDULING_PROFILE=multi-cloud-balanced

# CI/CD
MOADEV_GITOPS_REPOSITORY=github.com/dpwns523/MoaDev
MOADEV_GITOPS_REVISION=main
MOADEV_CI_ARTIFACT_RETENTION_DAYS=14
MOADEV_CD_SYNC_WAVE=10

# Monitoring
MOADEV_PROMETHEUS_RETENTION=15d
MOADEV_LOKI_RETENTION=7d
MOADEV_ALERT_ROUTE_EMAIL=platform-alerts@example.invalid
MOADEV_GRAFANA_ADMIN_GROUP=platform-admins

# Storage
MOADEV_ARTIFACT_BUCKET=moadev-artifacts-example
MOADEV_BACKUP_BUCKET=moadev-backups-example

# Cost automation
MOADEV_COST_CENTER=engineering-platform
MOADEV_MONTHLY_BUDGET_USD=500
MOADEV_IDLE_SCALE_DOWN_ENABLED=true
MOADEV_IDLE_SCALE_DOWN_SCHEDULE="0 22 * * 1-5"
MOADEV_COST_REPORT_SCHEDULE="0 9 * * 1"
