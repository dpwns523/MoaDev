# Sample only. Layer these OCI-specific values on top of global.env.example outside version control.

# OCI cluster
MOADEV_OCI_REGION=ap-seoul-1
MOADEV_OCI_TENANCY_OCID=ocid1.tenancy.oc1..exampleuniqueid
MOADEV_OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..exampleuniqueid
MOADEV_OCI_VCN_OCID=ocid1.vcn.oc1.ap-seoul-1.exampleuniqueid
MOADEV_OCI_WORKER_SUBNET_OCIDS=ocid1.subnet.oc1.ap-seoul-1.exampleworker1,ocid1.subnet.oc1.ap-seoul-1.exampleworker2
MOADEV_OCI_INGRESS_SUBNET_OCIDS=ocid1.subnet.oc1.ap-seoul-1.examplelb1,ocid1.subnet.oc1.ap-seoul-1.examplelb2
MOADEV_OCI_CLUSTER_NAME=moadev-oke
MOADEV_OCI_KUBERNETES_VERSION=v1.30.1
MOADEV_OCI_NODE_POOL_NAME=moadev-general
MOADEV_OCI_NODE_POOL_SHAPE=VM.Standard.E4.Flex
MOADEV_OCI_NODE_POOL_SIZE=3

# OCI ingress and storage overrides
MOADEV_OCI_BLOCK_VOLUME_STORAGE_CLASS=oci-bv
MOADEV_OCI_LOAD_BALANCER_SHAPE=flexible
MOADEV_OCI_LOAD_BALANCER_MIN_MBPS=10
MOADEV_OCI_LOAD_BALANCER_MAX_MBPS=100
MOADEV_OCI_WORKLOAD_PLACEMENT=availability-domain-spread
