# Sample only. Copy to terraform.tfvars and replace with environment-specific values outside version control.
# Environment is selected by this directory path, not by a provider-specific variable.

service_name      = "moadev"
platform_topology = "multicloud"

shared_labels = {
  naming_prefix_pattern = "moadev-{environment}"
  labels = [
    "service",
    "environment",
    "track",
    "managed_by",
    "cost_center",
  ]
}

cluster_topology = {
  cluster_name           = "moadev-prod-multicloud"
  kubernetes_version     = "1.34.2"
  control_plane_provider = "aws"
  cni_plugin             = "calico"
  pod_cidr               = "10.0.0.0/16"
  service_cidr           = "10.96.0.0/12"
  node_groups = {
    aws_control_plane = {
      provider         = "aws"
      role             = "control-plane"
      desired_count    = 1
      min_count        = 1
      max_count        = 5
      scaling_strategy = "manual"
    }
    aws_workers = {
      provider         = "aws"
      role             = "worker"
      desired_count    = 3
      min_count        = 3
      max_count        = 8
      scaling_strategy = "manual"
    }
    oci_workers = {
      provider         = "oci"
      role             = "worker"
      desired_count    = 3
      min_count        = 3
      max_count        = 8
      scaling_strategy = "manual"
    }
  }
}

domains = {
  base    = "moadev.example.invalid"
  web     = "app.moadev.example.invalid"
  api     = "api.moadev.example.invalid"
  argocd  = "argocd.moadev.example.invalid"
  grafana = "grafana.moadev.example.invalid"
}

images = {
  registry                  = "registry.example.invalid/moadev"
  web_repository            = "web"
  api_repository            = "api"
  agents_runtime_repository = "agents-runtime"
  tag                       = "2026.03"
}

namespaces = {
  app        = "moadev"
  platform   = "moadev-platform"
  monitoring = "moadev-monitoring"
  cicd       = "moadev-cicd"
}

ingress = {
  class_name             = "nginx"
  controller_replicas    = 3
  external_dns_zone      = "moadev.example.invalid"
  load_balancer_provider = "aws"
  load_balancer_scheme   = "internet-facing"
}

scheduling = {
  default_node_group     = "aws_workers"
  profile                = "multi-cloud-high-availability"
  topology_spread_policy = "hard"
}

cicd = {
  gitops_repository          = "github.com/dpwns523/MoaDev"
  gitops_revision            = "main"
  sync_wave                  = 20
  ci_artifact_retention_days = 30
}

monitoring = {
  prometheus_retention = "30d"
  loki_retention       = "14d"
  grafana_admin_group  = "platform-admins"
  alert_route_email    = "platform-alerts@example.invalid"
}

storage = {
  artifact_bucket   = "moadev-prod-artifacts-example"
  backup_bucket     = "moadev-prod-backups-example"
  snapshot_schedule = "0 1 * * *"
}

cost_automation = {
  cost_center              = "engineering-platform-prod"
  monthly_budget_usd       = 1500
  idle_scale_down_enabled  = false
  idle_scale_down_schedule = "0 23 * * 6"
  report_schedule          = "0 8 * * 1"
}

aws_dev_scheduler = {
  enabled        = false
  target_scope   = "disabled"
  start_schedule = ""
  stop_schedule  = ""
}

# Network mode stays explicit so the env root can switch between create/reference without changing module wiring.
oci_cluster = {
  region               = "ap-osaka-1"
  tenancy_ocid         = "ocid1.tenancy.oc1..exampleuniqueid"
  compartment_ocid     = "ocid1.compartment.oc1..exampleuniqueid"
  network_mode         = "create"
  vcn_cidr             = "10.50.0.0/16"
  availability_domains = ["AD-1", "AD-2"]
  worker_subnet_cidrs = [
    "10.50.10.0/24",
    "10.50.11.0/24",
  ]
  worker_shape           = "VM.Standard.E4.Flex"
  worker_ocpus           = 2
  worker_memory_gbs      = 16
  worker_boot_volume_gbs = 80
  workload_placement_intent = "availability-domain-spread"
  worker_placement_intent   = "private-subnets"
  bastion_enabled        = false
  storage_class          = "oci-bv"
  nat_gateway_enabled    = true
  image_ocid             = "ocid1.image.oc1.ap-osaka-1.exampleuniqueid"
  ssh_authorized_keys    = "ssh-ed25519 AAAA...REPLACE_ME_PROD_PUBLIC_KEY"
  bootstrap_template_path = "../../templates/oci-node-init.sh.tftpl"
  security_profile       = "kubespray-default"
  ssh_access_mode        = "cidr_allowlist"
  admin_ingress_cidrs    = ["203.0.113.10/32"]
  cluster_internal_cidrs = ["10.31.0.0/16", "10.50.0.0/16"]
}

aws_cluster = {
  region                            = "us-west-2"
  account_id                        = "123456789012"
  network_mode                      = "create"
  vpc_cidr                          = "10.31.0.0/16"
  availability_zones                = ["us-west-2a", "us-west-2b"]
  control_plane_subnet_cidrs        = ["10.31.10.0/24", "10.31.11.0/24"]
  worker_subnet_cidrs               = ["10.31.20.0/24", "10.31.21.0/24"]
  public_load_balancer_subnet_cidrs = ["10.31.30.0/24", "10.31.31.0/24"]
  control_plane_instance_type       = "t3.large"
  worker_instance_type              = "t3.large"
  control_plane_root_volume_gbs     = 60
  worker_root_volume_gbs            = 80
  worker_spot_enabled               = false
  control_plane_endpoint_access_intent = "private_only"
  control_plane_placement_intent       = "private-subnets"
  worker_placement_intent              = "private-subnets"
  bastion_enabled                   = false
  storage_class                     = "gp3"
  nat_gateway_enabled               = true
  nat_gateway_mode                  = "single"
  ami_id                            = "ami-0123456789example0"
  ssh_key_name                      = "REPLACE_ME_PROD_AWS_KEY"
  instance_profile_name             = "REPLACE_ME_PROD_AWS_NODE_PROFILE"
  bootstrap_template_path           = "../../templates/aws-node-init.sh.tftpl"
  security_profile                  = "kubespray-default"
  ssh_access_mode                   = "cidr_allowlist"
  admin_ingress_cidrs               = ["203.0.113.10/32"]
  kube_api_access_mode              = "private_only"
  kube_api_ingress_cidrs            = []
  cluster_internal_cidrs            = ["10.31.0.0/16", "10.50.0.0/16"]
}
