# Sample only. Copy to terraform.tfvars and replace with environment-specific values outside version control.
# Environment is selected by this directory path, not by a provider-specific variable.

service_name      = "moadev"
platform_topology = "multicloud"

shared_labels = {
  naming_prefix_pattern = "moadev-{environment}"
  labels = [
    "service",
    "environment",
    "track",
    "managed_by",
    "cost_center",
  ]
}

cluster_topology = {
  cluster_name           = "moadev-dev-multicloud"
  kubernetes_version     = "1.34.2"
  control_plane_provider = "aws"
  cni_plugin             = "calico"
  pod_cidr               = "10.0.0.0/16"
  service_cidr           = "10.96.0.0/12"
  node_groups = {
    aws_control_plane = {
      provider         = "aws"
      role             = "control-plane"
      desired_count    = 1
      min_count        = 1
      max_count        = 3
      scaling_strategy = "manual"
    }
    aws_workers = {
      provider         = "aws"
      role             = "worker"
      desired_count    = 3
      min_count        = 3
      max_count        = 6
      scaling_strategy = "manual"
    }
    oci_workers = {
      provider         = "oci"
      role             = "worker"
      desired_count    = 3
      min_count        = 3
      max_count        = 6
      scaling_strategy = "manual"
    }
  }
}

domains = {
  base    = "dev.moadev.example.invalid"
  web     = "app.dev.moadev.example.invalid"
  api     = "api.dev.moadev.example.invalid"
  argocd  = "argocd.dev.moadev.example.invalid"
  grafana = "grafana.dev.moadev.example.invalid"
}

images = {
  registry                  = "registry.example.invalid/moadev"
  web_repository            = "web"
  api_repository            = "api"
  agents_runtime_repository = "agents-runtime"
  tag                       = "2026.03-dev"
}

namespaces = {
  app        = "moadev-dev"
  platform   = "moadev-platform-dev"
  monitoring = "moadev-monitoring-dev"
  cicd       = "moadev-cicd-dev"
}

ingress = {
  class_name             = "nginx"
  controller_replicas    = 2
  external_dns_zone      = "dev.moadev.example.invalid"
  load_balancer_provider = "aws"
  load_balancer_scheme   = "internet-facing"
}

scheduling = {
  default_node_group     = "aws_workers"
  profile                = "multi-cloud-balanced"
  topology_spread_policy = "soft"
}

cicd = {
  gitops_repository          = "github.com/dpwns523/MoaDev"
  gitops_revision            = "main"
  sync_wave                  = 10
  ci_artifact_retention_days = 14
}

monitoring = {
  prometheus_retention = "15d"
  loki_retention       = "7d"
  grafana_admin_group  = "platform-admins"
  alert_route_email    = "platform-alerts@example.invalid"
}

storage = {
  artifact_bucket   = "moadev-dev-artifacts-example"
  backup_bucket     = "moadev-dev-backups-example"
  snapshot_schedule = "0 2 * * *"
}

cost_automation = {
  cost_center              = "engineering-platform-dev"
  monthly_budget_usd       = 250
  idle_scale_down_enabled  = true
  idle_scale_down_schedule = "0 22 * * 1-5"
  report_schedule          = "0 9 * * 1"
}

aws_dev_scheduler = {
  enabled        = true
  target_scope   = "workers_only"
  start_schedule = "TODO: set aws worker start schedule"
  stop_schedule  = "TODO: set aws worker stop schedule"
}

# Network mode stays explicit so the env root can switch between create/reference without changing module wiring.
oci_cluster = {
  region               = "ap-seoul-1"
  tenancy_ocid         = "ocid1.tenancy.oc1..exampleuniqueid"
  compartment_ocid     = "ocid1.compartment.oc1..exampleuniqueid"
  network_mode         = "create"
  vcn_cidr             = "10.40.0.0/16"
  availability_domains = ["AD-1", "AD-2"]
  worker_subnet_cidrs = [
    "10.40.10.0/24",
    "10.40.11.0/24",
  ]
  worker_shape           = "VM.Standard.E4.Flex"
  worker_ocpus           = 2
  worker_memory_gbs      = 16
  worker_boot_volume_gbs = 80
  workload_placement     = "availability-domain-spread"
  worker_placement       = "private-subnets"
  bastion_enabled        = false
  storage_class          = "oci-bv"
}

aws_cluster = {
  region                            = "us-west-2"
  account_id                        = "123456789012"
  network_mode                      = "create"
  vpc_cidr                          = "10.30.0.0/16"
  availability_zones                = ["us-west-2a", "us-west-2b"]
  control_plane_subnet_cidrs        = ["10.30.10.0/24", "10.30.11.0/24"]
  worker_subnet_cidrs               = ["10.30.20.0/24", "10.30.21.0/24"]
  public_load_balancer_subnet_cidrs = ["10.30.30.0/24", "10.30.31.0/24"]
  control_plane_instance_type       = "t3.large"
  worker_instance_type              = "t3.large"
  control_plane_root_volume_gbs     = 60
  worker_root_volume_gbs            = 80
  worker_spot_enabled               = false
  control_plane_endpoint_access     = "private"
  control_plane_placement           = "private-subnets"
  worker_placement                  = "private-subnets"
  bastion_enabled                   = false
  storage_class                     = "gp3"
}
